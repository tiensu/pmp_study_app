flowchart TB

%% =========================
%% 1. PHASE FLOW
%% =========================
A[Initiating] --> B[Planning]
B --> C[Executing]
C --> D[Monitoring & Controlling]
D --> C
C --> E[Closing]

%% =========================
%% 2. INITIATING
%% =========================
subgraph INIT[Initiating]
I1[Develop Project Charter]
I2[Identify Stakeholders]
I1 --> O1[Project Charter]
I2 --> O2[Stakeholder Register]
end

%% =========================
%% 3. PLANNING
%% =========================
subgraph PLAN[Planning]
P0[Develop Project Management Plan]

subgraph SUBS[Subsidiary Plans]
SP1[Scope Management Plan]
SP2[Schedule Management Plan]
SP3[Cost Management Plan]
SP4[Quality Management Plan]
SP5[Resource Management Plan]
SP6[Communications Management Plan]
SP7[Risk Management Plan]
SP8[Procurement Management Plan]
SP9[Stakeholder Engagement Plan]
end

subgraph SCOPE[Scope Planning]
P1[Collect Requirements]
P2[Define Scope]
P3[Create WBS]
R1[Requirements Documentation]
R2[Requirements Traceability Matrix]
R3[Project Scope Statement]
R4[WBS]
R5[WBS Dictionary]
P1 --> R1
P1 --> R2
P2 --> R3
P3 --> R4
P3 --> R5
end

subgraph SCHEDULE[Schedule Planning]
P4[Define Activities]
P5[Sequence Activities]
P6[Estimate Activity Durations]
P7[Develop Schedule]
SB[Schedule Baseline]
P4 --> P5 --> P6 --> P7 --> SB
end

subgraph COST[Cost Planning]
P8[Estimate Costs]
P9[Determine Budget]
CB[Cost Baseline]
P8 --> P9 --> CB
end

subgraph QUALITY[Quality Planning]
P10[Plan Quality Management]
end

subgraph RESOURCE[Resource Planning]
P11[Plan Resource Management]
P12[Estimate Activity Resources]
RB[RBS - Resource Breakdown Structure]
P11 --> P12 --> RB
end

subgraph COMM[Communication Planning]
P13[Plan Communications Management]
end

subgraph RISK[Risk Planning]
P14[Plan Risk Management]
P15[Identify Risks]
P16[Perform Qualitative Risk Analysis]
P17[Perform Quantitative Risk Analysis]
P18[Plan Risk Responses]
RR[Risk Register / Risk Report / Risk Responses]
P14 --> P15 --> P16 --> P17 --> P18 --> RR
end

subgraph PROC[Procurement Planning]
P19[Plan Procurement Management]
end

subgraph STAKE[Stakeholder Planning]
P20[Plan Stakeholder Engagement]
end

P0 --> SUBS
P0 --> SCOPE
P0 --> SCHEDULE
P0 --> COST
P0 --> QUALITY
P0 --> RESOURCE
P0 --> COMM
P0 --> RISK
P0 --> PROC
P0 --> STAKE

PMP[Integrated Project Management Plan]
SUBS --> PMP
SCOPE --> PMP
SCHEDULE --> PMP
COST --> PMP
QUALITY --> PMP
RESOURCE --> PMP
COMM --> PMP
RISK --> PMP
PROC --> PMP
STAKE --> PMP
end

%% =========================
%% 4. EXECUTING
%% =========================
subgraph EXEC[Executing]
E1[Direct and Manage Project Work]
E2[Manage Quality]
E3[Acquire Resources]
E4[Develop Team]
E5[Manage Team]
E6[Manage Communications]
E7[Implement Risk Responses]
E8[Conduct Procurements]
E9[Manage Stakeholder Engagement]
DEL[Deliverables]
E1 --> DEL
end

%% =========================
%% 5. MONITORING & CONTROLLING
%% =========================
subgraph MC[Monitoring & Controlling]
M1[Monitor and Control Project Work]
M2[Perform Integrated Change Control]
M3[Validate Scope]
M4[Control Scope]
M5[Control Schedule]
M6[Control Costs]
M7[Control Quality]
M8[Control Resources]
M9[Monitor Communications]
M10[Monitor Risks]
M11[Control Procurements]
M12[Monitor Stakeholder Engagement]

WPD[Work Performance Data]
WPI[Work Performance Information]
WPR[Work Performance Reports]

WPD --> WPI --> WPR

ISSUE[Issue / Variance / Risk Trigger]
CR[Change Request]
CCB[CCB Review]
APP[Approved Change]
REJ[Rejected Change]

ISSUE --> CR --> M2 --> CCB
CCB --> APP
CCB --> REJ

A1[Corrective Action]
A2[Preventive Action]
A3[Defect Repair]

APP --> A1
APP --> A2
APP --> A3
end

%% =========================
%% 6. CLOSING
%% =========================
subgraph CLOSE[Closing]
C1[Close Project or Phase]
F1[Final Product / Service / Result Transition]
F2[Final Report]
F3[Lessons Learned Register Update]
F4[Lessons Learned Repository]
F5[OPA Updates / Archive]
C1 --> F1
C1 --> F2
C1 --> F3
C1 --> F4
C1 --> F5
end

%% =========================
%% 7. CROSS-FLOW CONNECTIONS
%% =========================
O1 --> P0
O2 --> P0
PMP --> E1
DEL --> M3
DEL --> M7
DEL --> C1
WPR --> C1
RR --> E7
RR --> M10
SB --> M5
CB --> M6
RB --> E3